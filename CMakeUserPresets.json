{
    "version": 8,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "$env{HOME}/.cache/build/${sourceDirName}/${presetName}",
            "generator": "Unix Makefiles",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "$env{HOME}/.local/$env{MACHINE}",
                "CMAKE_PREFIX_PATH": "$env{HOME}/.local/$env{MACHINE}",
                "CMAKE_FIND_ROOT_PATH_MODE_PROGRAM": "NEVER",
                "CMAKE_FIND_ROOT_PATH_MODE_LIBRARY": "ONLY",
                "CMAKE_FIND_ROOT_PATH_MODE_INCLUDE": "ONLY",
                "CMAKE_FIND_ROOT_PATH_MODE_PACKAGE": "ONLY"
            }
        },
        {
            "name": "linux",
            "hidden": true,
            "inherits": "base",
            "description": "Build for Linux"
        },
        {
            "name": "linux_release",
            "displayName": "Linux release",
            "inherits": "linux",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "linux_debug",
            "displayName": "Linux debug",
            "inherits": "linux",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "emc",
            "hidden": true,
            "inherits": "base",
            "description": "Build with emscripten",
            "toolchainFile": "$env{EMROOT}/cmake/Modules/Platform/Emscripten.cmake"
        },
        {
            "name": "emc_debug",
            "displayName": "Emscripten debug",
            "inherits": "emc",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "emc_release",
            "displayName": "Emscripten release",
            "inherits": "emc",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "mingw",
            "hidden": true,
            "inherits": "base",
            "description": "Cross-compiling for Windows using mingw",
            "cacheVariables": {
                "WIN32": "ON",
                "CMAKE_SYSTEM_NAME": "Windows",
                "CMAKE_SYSTEM_PROCESSOR": "x86_64",
                "CMAKE_C_COMPILER": "x86_64-w64-mingw32-gcc",
                "CMAKE_CXX_COMPILER": "x86_64-w64-mingw32-g++",
                "CMAKE_FIND_ROOT_PATH": "/usr/x86_64-w64-mingw32"
            }
        },
        {
            "name": "mingw_debug",
            "displayName": "MinGW debug (Nix Cross)",
            "inherits": "mingw",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "mingw_release",
            "displayName": "MinGW release (Nix Cross)",
            "inherits": "mingw",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "linux_debug",
            "displayName": "Linux debug",
            "configurePreset": "linux_debug"
        },
        {
            "name": "linux_release",
            "displayName": "Linux release",
            "configurePreset": "linux_release"
        },
        {
            "name": "emc_debug",
            "displayName": "Emscripten debug",
            "configurePreset": "emc_debug"
        },
        {
            "name": "emc_release",
            "displayName": "Emscripten release",
            "configurePreset": "emc_release"
        },
        {
            "name": "mingw_debug",
            "displayName": "Mingw debug",
            "configurePreset": "mingw_debug"
        },
        {
            "name": "mingw_release",
            "displayName": "Mingw release",
            "configurePreset": "mingw_release"
        }
    ]
}
